{% load static %}
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gunners Pulse — My Tactics</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="{% static 'css/tactics_p.css' %}" />
    <link href="{% static 'css/notification.css' %}" rel="stylesheet" />
  </head>
  <body>
    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-logo">
        <img
          class="siteLogo"
          id="siteLogo"
          src="{% static 'images/white_gun_p.jpg' %}"
          alt="Gunners Pulse"
          onerror="this.style.display = 'none'"
        />
      </div>
      <nav class="sidebar-nav">
        <a class="nav-link-item" href="{% url 'player_home' %}"
          ><span class="material-symbols-outlined">home</span
          ><span>Home</span></a>
        <a class="nav-link-item" href="{% url 'player_performance' %}"
          ><span class="material-symbols-outlined">monitoring</span
          ><span>My Performance</span></a>
        <a class="nav-link-item active" href="{% url 'player_tactics' %}"
          ><span class="material-symbols-outlined">strategy</span
          ><span> Tactics</span></a>
        <a class="nav-link-item" href="{% url 'player_training' %}"
          ><span class="material-symbols-outlined">fitness_center</span
          ><span>Training</span></a>
        <a class="nav-link-item" href="{% url 'player_calendar' %}"
          ><span class="material-symbols-outlined">calendar_month</span
          ><span>Calendar</span></a>
        <a class="nav-link-item" href="{% url 'admin:index' %}"
          ><span class="material-symbols-outlined">settings</span
          ><span>Settings</span></a
        >
      </nav>
      <div class="sidebar-footer">
        <a class="nav-link-item" href="{% url 'logout' %}"
          ><span class="material-symbols-outlined">logout</span
          ><span>Logout</span></a>
      </div>
    </aside>
    <div class="mob-overlay" id="mobOverlay"></div>

    <!-- MAIN -->
    <div class="main-wrap">
      <header class="top-header">
        <button
          class="hamburger-btn d-lg-none"
          id="sidebarToggle"
          aria-label="Open menu"
        >
          <span class="material-symbols-outlined">menu</span>
        </button>
        <div class="header-title">
          <h1>Team Tactics</h1>
          <p>Shared by Coach Arteta</p>
        </div>
        <div class="header-center"></div>
        <div class="header-actions">
          <div
            class="theme-toggle-btn"
            id="themeToggle"
            title="Toggle dark mode"
          >
            <span class="material-symbols-outlined" id="themeIcon"
              >dark_mode</span
            >
          </div>
          <div class="notif-btn" id="notifBtn" title="Notifications">
            <span class="material-symbols-outlined">notifications</span>
            <span class="notif-dot" id="notifDot" style="display: none"></span>
            <span class="notif-count" id="notifCount" style="display: none"
              >0</span
            >
          </div>
          <div class="user-profile">
            <div class="text-end d-none d-md-block">
              <div class="user-name">Bukayo Saka</div>
              <div class="user-role">Right Winger · #7</div>
            </div>
            <img
              class="avatar"
              src="{% static 'images/saka_p.jpg' %}"
              alt="Saka"
              onerror="
                this.onerror = null;
                this.src = 'https://placehold.co/40/ec0024/fff?text=7';
              "
            />
          </div>
        </div>
      </header>

      <div class="tactics-body">
        <div class="page-body">
          <!-- LEFT PANEL: Team Tactics (read-only) -->
          <div class="left-panel">
            <!-- Formation info -->
            <div
              class="panel-section formation-summary"
              id="formation-summary-panel"
            >
              <div class="panel-title">
                <span class="material-symbols-outlined">grid_view</span>Current
                Formation
                <span
                  class="section-updated-badge"
                  id="badge-formation"
                  style="display: none"
                  >UPDATED</span
                >
              </div>
              <div class="formation-name-display" id="formation-name-display">
                —
              </div>
              <div class="formation-style-row" id="formation-style-row"></div>
              <div
                class="formation-desc-display"
                id="formation-desc-display"
              ></div>
            </div>

            <!-- Defensive Tactics -->
            <div class="panel-section panel-section-collapsible" id="sec-def">
              <div
                class="panel-title panel-title-toggle"
                data-section="sec-def"
              >
                <span class="material-symbols-outlined">shield</span>Defensive
                Tactics
                <span
                  class="section-updated-badge"
                  id="badge-def"
                  style="display: none"
                  >UPDATED</span
                >
                <span class="material-symbols-outlined section-chevron"
                  >expand_more</span
                >
              </div>
              <div class="section-body">
                <div class="ro-row">
                  <span class="ro-label">Style</span
                  ><span class="ro-val" id="v-def-style">—</span>
                </div>
                <div class="ro-row">
                  <span class="ro-label">Pressing Trigger</span
                  ><span class="ro-val" id="v-press-trigger">—</span>
                </div>
                <div class="ro-row">
                  <span class="ro-label">Pressing Intensity</span>
                  <div class="ro-bar-wrap">
                    <div class="ro-bar" id="bar-press-int"></div>
                    <span class="ro-bar-val" id="v-press-int">—</span>
                  </div>
                </div>
                <div class="ro-row">
                  <span class="ro-label">Offside Trap</span
                  ><span class="ro-val ro-pill" id="v-offside">—</span>
                </div>
                <div class="ro-row">
                  <span class="ro-label">Width</span>
                  <div class="ro-bar-wrap">
                    <div class="ro-bar" id="bar-def-width"></div>
                    <span class="ro-bar-val" id="v-def-width">—</span>
                  </div>
                </div>
                <div class="ro-row">
                  <span class="ro-label">Line Height</span>
                  <div class="ro-bar-wrap">
                    <div class="ro-bar" id="bar-def-depth"></div>
                    <span class="ro-bar-val" id="v-def-depth">—</span>
                  </div>
                </div>
                <div class="ro-row">
                  <span class="ro-label">Transition</span
                  ><span class="ro-val" id="v-trans-def">—</span>
                </div>
                <div class="tac-sub-title">Set Pieces — Defending</div>
                <div class="ro-row">
                  <span class="ro-label">Corner Defence</span
                  ><span class="ro-val" id="v-corner-def">—</span>
                </div>
                <div class="ro-row">
                  <span class="ro-label">Free Kick Shape</span
                  ><span class="ro-val" id="v-fk-def">—</span>
                </div>
              </div>
            </div>

            <!-- Offensive Tactics -->
            <div class="panel-section panel-section-collapsible" id="sec-off">
              <div
                class="panel-title panel-title-toggle"
                data-section="sec-off"
              >
                <span class="material-symbols-outlined">sports_soccer</span
                >Offensive Tactics
                <span
                  class="section-updated-badge"
                  id="badge-off"
                  style="display: none"
                  >UPDATED</span
                >
                <span class="material-symbols-outlined section-chevron"
                  >expand_more</span
                >
              </div>
              <div class="section-body">
                <div class="ro-row">
                  <span class="ro-label">Build Up Play</span
                  ><span class="ro-val" id="v-build-play">—</span>
                </div>
                <div class="ro-row">
                  <span class="ro-label">Chance Creation</span
                  ><span class="ro-val" id="v-chance-creation">—</span>
                </div>
                <div class="ro-row">
                  <span class="ro-label">Transition to Attack</span
                  ><span class="ro-val" id="v-trans-att">—</span>
                </div>
                <div class="ro-row">
                  <span class="ro-label">Crossing Style</span
                  ><span class="ro-val" id="v-cross-style">—</span>
                </div>
                <div class="ro-row">
                  <span class="ro-label">Crossing Frequency</span>
                  <div class="ro-bar-wrap">
                    <div class="ro-bar" id="bar-cross-freq"></div>
                    <span class="ro-bar-val" id="v-cross-freq">—</span>
                  </div>
                </div>
                <div class="ro-row">
                  <span class="ro-label">Width</span>
                  <div class="ro-bar-wrap">
                    <div class="ro-bar" id="bar-off-width"></div>
                    <span class="ro-bar-val" id="v-off-width">—</span>
                  </div>
                </div>
                <div class="ro-row">
                  <span class="ro-label">Players In Box</span>
                  <div class="ro-bar-wrap">
                    <div
                      class="ro-bar ro-bar-small"
                      id="bar-pib"
                      style="--max: 6"
                    ></div>
                    <span class="ro-bar-val" id="v-pib">—</span>
                  </div>
                </div>
                <div class="tac-sub-title">Set Pieces — Attacking</div>
                <div class="ro-row">
                  <span class="ro-label">Corner Routine</span
                  ><span class="ro-val" id="v-corner-att">—</span>
                </div>
                <div class="ro-row">
                  <span class="ro-label">Free Kick Routine</span
                  ><span class="ro-val" id="v-fk-att">—</span>
                </div>
                <div class="ro-row">
                  <span class="ro-label">Players on Post</span
                  ><span class="ro-val" id="v-post">—</span>
                </div>
              </div>
            </div>

            <!-- Set Piece Takers -->
            <div class="panel-section panel-section-collapsible" id="sec-spt">
              <div
                class="panel-title panel-title-toggle"
                data-section="sec-spt"
              >
                <span class="material-symbols-outlined">flag</span>Set Piece
                Takers
                <span
                  class="section-updated-badge"
                  id="badge-spt"
                  style="display: none"
                  >UPDATED</span
                >
                <span class="material-symbols-outlined section-chevron"
                  >expand_more</span
                >
              </div>
              <div class="section-body">
                <div class="spt-grid" id="spt-grid"></div>
              </div>
            </div>
          </div>

          <!-- PITCH -->
          <div class="pitch-area">
            <div class="pitch-container">
              <div class="pitch" id="pitch">
                <svg
                  class="pitch-lines"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 760 560"
                  preserveAspectRatio="none"
                >
                  <rect
                    x="20"
                    y="16"
                    width="720"
                    height="528"
                    fill="none"
                    stroke="rgba(255,255,255,0.5)"
                    stroke-width="1.5"
                  />
                  <line
                    x1="20"
                    y1="280"
                    x2="740"
                    y2="280"
                    stroke="rgba(255,255,255,0.5)"
                    stroke-width="1.5"
                  />
                  <circle
                    cx="380"
                    cy="280"
                    r="70"
                    fill="none"
                    stroke="rgba(255,255,255,0.5)"
                    stroke-width="1.5"
                  />
                  <circle
                    cx="380"
                    cy="280"
                    r="4"
                    fill="rgba(255,255,255,0.6)"
                  />
                  <rect
                    x="220"
                    y="16"
                    width="320"
                    height="100"
                    fill="none"
                    stroke="rgba(255,255,255,0.5)"
                    stroke-width="1.5"
                  />
                  <rect
                    x="300"
                    y="16"
                    width="160"
                    height="44"
                    fill="none"
                    stroke="rgba(255,255,255,0.5)"
                    stroke-width="1.5"
                  />
                  <rect
                    x="220"
                    y="444"
                    width="320"
                    height="100"
                    fill="none"
                    stroke="rgba(255,255,255,0.5)"
                    stroke-width="1.5"
                  />
                  <rect
                    x="300"
                    y="500"
                    width="160"
                    height="44"
                    fill="none"
                    stroke="rgba(255,255,255,0.5)"
                    stroke-width="1.5"
                  />
                  <circle cx="380" cy="90" r="3" fill="rgba(255,255,255,0.5)" />
                  <circle
                    cx="380"
                    cy="470"
                    r="3"
                    fill="rgba(255,255,255,0.5)"
                  />
                </svg>
              </div>
            </div>
            <!-- My Position Highlight Card -->
            <div class="my-role-bar" id="my-role-bar">
              <div class="my-role-inner">
                <img
                  class="my-role-avatar"
                  src="{% static 'images/saka_p.jpg' %}"
                  alt="Saka"
                  onerror="
                    this.src = 'https://placehold.co/44/ec0024/fff?text=7'
                  "
                />
                <div class="my-role-info">
                  <div class="my-role-name">
                    Your Role
                    <span class="my-pos-badge" id="my-pos-badge"></span>
                    <span
                      class="section-updated-badge"
                      id="badge-my-role"
                      style="display: none"
                      >UPDATED</span
                    >
                  </div>
                  <div class="my-role-title" id="my-role-title">—</div>
                  <div class="my-role-focus-row">
                    <span class="my-focus-pill" id="my-focus-pill">—</span>
                    <span class="my-defsup" id="my-defsup">—</span>
                  </div>
                </div>
                <div class="my-role-desc" id="my-role-desc">—</div>
              </div>
              <!-- Instructions -->
              <div class="my-instrs" id="my-instrs" style="display: none">
                <div class="my-instrs-label">Your Instructions</div>
                <div class="my-instrs-pills" id="my-instrs-pills"></div>
              </div>
              <!-- Coach Notes -->
              <div
                class="my-notes-wrap"
                id="my-notes-wrap"
                style="display: none"
              >
                <div class="my-notes-label">
                  <span class="material-symbols-outlined">edit_note</span>Coach
                  Note
                </div>
                <div class="my-notes-text" id="my-notes-text"></div>
              </div>
            </div>
          </div>

          <!-- RIGHT PANEL: Click a player to see their info -->
          <div class="right-panel">
            <div id="rp-empty" class="panel-section rp-empty-state">
              <span
                class="material-symbols-outlined"
                style="font-size: 48px; color: var(--border2)"
                >person_search</span
              >
              <p
                style="
                  font-size: 13px;
                  color: var(--text3);
                  text-align: center;
                  line-height: 1.6;
                "
              >
                Click any player on the pitch to view their role and tactical
                instructions
              </p>
            </div>
            <div
              id="rp-player"
              style="
                display: none;
                flex-direction: column;
                height: 100%;
                overflow-y: auto;
              "
            >
              <div class="panel-section rp-header">
                <div class="rp-player-row">
                  <img id="rp-avatar" class="rp-avatar" src="" alt="" />
                  <div>
                    <div id="rp-name" class="rp-name"></div>
                    <div
                      style="
                        display: flex;
                        align-items: center;
                        gap: 6px;
                        margin-top: 3px;
                      "
                    >
                      <span id="rp-pos-badge" class="player-info-pos"></span>
                      <span
                        id="rp-number"
                        style="font-size: 11px; color: var(--text3)"
                      ></span>
                    </div>
                  </div>
                  <button class="rp-close-btn" id="rp-close" title="Close">
                    <span class="material-symbols-outlined">close</span>
                  </button>
                </div>
              </div>
              <div class="panel-section">
                <div class="panel-title">
                  <span class="material-symbols-outlined">assignment_ind</span
                  >Role
                </div>
                <div class="ro-val-big" id="rp-role-display">—</div>
                <div
                  id="rp-role-desc"
                  class="rp-desc-box"
                  style="margin-top: 8px"
                ></div>
              </div>
              <div class="panel-section">
                <div class="panel-title">
                  <span class="material-symbols-outlined">adjust</span>Focus
                </div>
                <div id="rp-focus-display" class="focus-pill-static"></div>
                <div
                  id="rp-focus-desc"
                  class="rp-desc-box"
                  style="margin-top: 8px"
                ></div>
              </div>
              <div class="panel-section">
                <div class="panel-title">
                  <span class="material-symbols-outlined">shield_person</span
                  >Defensive Support
                </div>
                <div class="defsup-display" id="rp-defsup-display">—</div>
              </div>
              <div
                class="panel-section"
                id="rp-instrs-sec"
                style="display: none"
              >
                <div class="panel-title">
                  <span class="material-symbols-outlined">tune</span>Player
                  Instructions
                </div>
                <div class="pi-pills-ro" id="rp-instrs-pills"></div>
              </div>
              <div
                class="panel-section"
                id="rp-notes-sec"
                style="display: none"
              >
                <div class="panel-title">
                  <span class="material-symbols-outlined">edit_note</span>Coach
                  Notes
                </div>
                <div class="coach-notes-ro" id="rp-notes-display"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tooltip -->
    <div class="tac-tooltip" id="tooltip">
      <div class="tooltip-title" id="tt-name"></div>
      <div class="tooltip-role" id="tt-role"></div>
      <div class="tooltip-focus" id="tt-focus"></div>
    </div>

    <!-- No tactic saved warning -->
    <div class="no-tactic-overlay" id="no-tactic-overlay" style="display: none">
      <div class="no-tactic-card">
        <span
          class="material-symbols-outlined"
          style="font-size: 52px; color: var(--primary)"
          >info</span
        >
        <div class="no-tactic-title">No Tactics Available Yet</div>
        <div class="no-tactic-sub">
          The coaching staff hasn't shared the tactics plan yet. Check back
          before the next training session.
        </div>
      </div>
    </div>

    <!-- ═══════════ NOTIFICATION TOAST CONTAINER ═══════════ -->
    <div class="tac-toast-container" id="toastContainer"></div>

    <!-- ═══════════ NOTIFICATION DROPDOWN ═══════════ -->
    <div class="notif-dropdown" id="notifDropdown">
      <div class="notif-dropdown-header">
        <span class="notif-dropdown-title">Notifications</span>
        <button class="notif-clear-btn" id="clearNotifsBtn">Clear all</button>
      </div>
      <div class="notif-dropdown-body" id="notifBody">
        <div class="notif-empty-state" id="notifEmptyState">
          <span
            class="material-symbols-outlined"
            style="font-size: 28px; color: var(--text4)"
            >notifications_off</span
          >
          <p>No new notifications</p>
        </div>
      </div>
    </div>

    
    
    
      <script>
      window.PLAYER_TACTICS_DATA = {{ player_tactics_json|default:"{}"|safe }};
    </script>

    <script src="{% static 'js/notification.js' %}"></script>
    <script src="{% static 'js/tactics-data_p.js' %}"></script>
    <script src="{% static 'js/tactics_p.js' %}"></script>
  </body>
</html>
